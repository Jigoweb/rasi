# Supabase client-side configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase server-side configuration
# Server/API scripts only. Do not prefix with NEXT_PUBLIC_, expose client-side, or commit real secrets.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional worker delegation for long-running jobs
NEXT_PUBLIC_WORKER_URL=http://localhost:8080

# External title metadata (search/import). Data source: OMDb (omdbapi.com).
# Get a free key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your-omdb-key
# Optional override of the OMDb base URL (defaults to https://www.omdbapi.com)
# OMDB_API_URL=https://www.omdbapi.com
