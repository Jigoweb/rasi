# Server
PORT=8080

# Supabase — usa gli STESSI valori del progetto Next.js
SUPABASE_URL=https://xxxxx.supabase.co
# Service role key: bypassa RLS, usata per le RPC server-side. TIENILA SEGRETA.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
# Anon key: serve solo per verificare il JWT dell'utente (auth.getUser)
SUPABASE_ANON_KEY=eyJhbGci...

# CORS: domini del frontend autorizzati a chiamare il worker, separati da virgola
# Es: https://rasi.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Dimensione del chunk di programmazioni per ogni RPC (default 500)
CHUNK_SIZE=500
