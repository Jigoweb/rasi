{
  "name": "rasi-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Worker Node.js per le operazioni onerose di RASI (individuazione, caricamento programmazioni). Orchestra le RPC Postgres senza i limiti di timeout serverless.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
